# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Bug Hunter API Key Template (KeyAtlas)
#
# Add these to ~/.zshrc (or ~/.bashrc) and fill in your actual keys.
# Never commit .env files with real values to version control.
#
# Quick setup:
#   cat .env.example >> ~/.zshrc
#   # Then open ~/.zshrc and replace each <YOUR_KEY> with the real value
#   source ~/.zshrc
#
# Get all dashboard links at: https://kdairatchi.github.io/keyatlas/
# ══════════════════════════════════════════════════════════════════════════════


# ── Hunt Platform Credentials ─────────────────────────────────────────────
# keyatlas: https://hackerone.com/settings/api_token/edit
export HACKERONE_API_TOKEN=<YOUR_KEY>
export HACKERONE_API_USERNAME=<YOUR_H1_HANDLE>

# keyatlas: https://bugcrowd.com/h/researcher/api_credentials
export BUGCROWD_API_TOKEN=<YOUR_KEY>

# keyatlas: https://app.intigriti.com/profile
export INTIGRITI_API_TOKEN=<YOUR_KEY>


# ── Subdomain Recon ───────────────────────────────────────────────────────
# PRIORITY: GitHub + Shodan + CHAOS cover ~70% of subdomains. Get these first.

# keyatlas: https://github.com/settings/tokens/new  (scopes: repo, read:org)
export GITHUB_TOKEN=<YOUR_PAT>

# keyatlas: https://account.shodan.io
export SHODAN_API_KEY=<YOUR_KEY>

# keyatlas: https://cloud.projectdiscovery.io
export CHAOS_KEY=<YOUR_KEY>

# keyatlas: https://search.censys.io/me
export CENSYS_API_ID=<YOUR_ID>
export CENSYS_API_SECRET=<YOUR_SECRET>

# keyatlas: https://securitytrails.com/app/account/credentials
export SECURITYTRAILS_API_KEY=<YOUR_KEY>

# keyatlas: https://app.netlas.io/profile/
export NETLAS_API_KEY=<YOUR_KEY>

# keyatlas: https://gitlab.com/-/profile/personal_access_tokens
export GITLAB_TOKEN=<YOUR_PAT>

# keyatlas: DISCONTINUED — acquired by Coalition (existing keys may work in subfinder)
export BINARYEDGE_API_KEY=<YOUR_KEY>

# keyatlas: https://leakix.net  (login → Account → API Key)
export LEAKIX_API_KEY=<YOUR_KEY>

# keyatlas: https://drs.whoisxmlapi.com
export WHOISXML_API_KEY=<YOUR_KEY>


# ── Threat Intel ─────────────────────────────────────────────────────────
# keyatlas: https://www.virustotal.com/gui/my-apikey
export VIRUSTOTAL_API_KEY=<YOUR_KEY>

# keyatlas: https://urlscan.io/user/profile
export URLSCAN_API_KEY=<YOUR_KEY>

# keyatlas: https://intelx.io/account?tab=developer
export INTELX_API_KEY=<YOUR_KEY>

# keyatlas: https://fofa.info/api
export FOFA_KEY=<YOUR_KEY>
export FOFA_EMAIL=<YOUR_FOFA_EMAIL>


# ── Notifications ────────────────────────────────────────────────────────
# keyatlas: https://discord.com/developers/applications
export DISCORD_WEBHOOK_URL=<YOUR_WEBHOOK_URL>

# keyatlas: https://t.me/BotFather  |  chat ID: message @userinfobot
export TELEGRAM_API_KEY=<YOUR_BOT_TOKEN>
export TELEGRAM_CHAT_ID=<YOUR_CHAT_ID>

# keyatlas: https://api.slack.com/apps
export SLACK_WEBHOOK_URL=<YOUR_WEBHOOK_URL>


# ── Local Tools ──────────────────────────────────────────────────────────
# Obsidian: Settings → Community Plugins → Local REST API → copy key
export OBSIDIAN_API_KEY=<YOUR_KEY>

# interactsh self-hosted: https://github.com/projectdiscovery/interactsh
export COLLAB_URL=<YOUR_INTERACTSH_URL>

# SearXNG (self-hosted search) — default port 8888
export SEARXNG_BASE_URL=http://localhost:8888
